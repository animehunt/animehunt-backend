# AnimeHunt backend — environment variables for the Node/VPS deployment
# Copy this to .env and fill in real values. Never commit the real .env file.

# ── Server ──
PORT=3000
ENVIRONMENT=production

# ── Redis (replaces Cloudflare KV) ──
# Local Redis on the same VPS: redis://127.0.0.1:6379
# Set a password in production: redis://:yourpassword@127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ── Turso (replaces Cloudflare D1 as primary database) ──
# Get these from `turso db show <your-db-name>` after creating/promoting
# your Turso database. Must be your PRIMARY database now, not just a replica.
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# ── Turso Replica #2 (DB3 — a SECOND, independent Turso database) ──
# Optional: leave both blank to skip DB3 entirely for now, same as leaving
# R2 blank below. Create it the same way as your primary
# (`turso db create your-db-name-replica`), just a different database.
TURSO_REPLICA_URL=
TURSO_REPLICA_AUTH_TOKEN=

# ── Supabase (unchanged — was already a replica, still is) ──
SUPABASE_URL=
SUPABASE_KEY=

# ── Secrets (previously set via `wrangler secret put`) ──
# Generate a long random string for each, e.g.: openssl rand -hex 32
JWT_SECRET=
ADMIN_INITIAL_PASSWORD=

# ── ImageKit (unchanged — was already an external SaaS, not Cloudflare-tied) ──
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL_ENDPOINT=

# ── CORS ──
# Comma-separated, no spaces around commas needed (they're trimmed).
ALLOWED_ORIGINS=https://animehunt.in,https://www.animehunt.in,https://admin.animehunt.in

# ── Cron replacement ──
# Any long random string — put the same value in your crontab's
# `Authorization: Bearer ...` header. See src/index.js's comment
# above the /internal/run-cron route for the crontab line to add.
CRON_SECRET=

# ── R2 (optional — only needed if you're keeping the DB snapshot/restore
#      feature in dbRestore.js. Leave all four blank to disable it, same
#      as an unbound Workers binding — nothing else breaks if you skip this.) ──
# Create an API token under Cloudflare dashboard -> R2 -> Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
