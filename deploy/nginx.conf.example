# nginx reverse proxy config example — replaces the TLS termination +
# routing that Cloudflare Workers handled for you automatically.
#
# Install: sudo cp this file to /etc/nginx/sites-available/animehunt
#          sudo ln -s /etc/nginx/sites-available/animehunt /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx
#
# Then get a real cert (Let's Encrypt, free):
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d animehunt.in -d www.animehunt.in -d admin.animehunt.in
# certbot will rewrite the server blocks below to add the actual ssl_certificate
# lines and an HTTP->HTTPS redirect automatically — the config below is the
# "before certbot" starting point.
#
# NOTE on §1.1 from the migration report: if you're keeping Cloudflare's
# orange-cloud proxy in front of this VPS (recommended — keeps
# CF-Connecting-IP working and gives you free DDoS protection), then
# Cloudflare is what terminates the public-facing TLS, and this nginx
# config only needs to listen on 80 (Cloudflare -> nginx -> Node can be
# plain HTTP on that hop, or use Cloudflare's "Full (strict)" mode with
# an Origin CA cert for encrypted all the way through). If you're going
# fully origin-direct, use the certbot flow above for real public TLS.

server {
    listen 80;
    server_name animehunt.in www.animehunt.in;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        # Only relevant if you go fully origin-direct (no Cloudflare in
        # front) — see report §1.1. If Cloudflare stays in front,
        # CF-Connecting-IP arrives already set and this header becomes
        # a secondary/backup signal, which is exactly what the code's
        # new fallback chain (CF-Connecting-IP -> x-forwarded-for) expects.
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

server {
    listen 80;
    server_name admin.animehunt.in;

    location / {
        # Serves the static admin panel (animehunt-admin-main/*.html).
        # Point this at wherever you copy those files on the VPS —
        # nginx can serve static files directly, no Node process needed
        # for the admin panel itself.
        root /var/www/animehunt-admin;
        index index.html;
        try_files $uri $uri.html $uri/ =404;
    }

    # index.html's `const API = "/api/admin"` (relative path, see report
    # §4) needs this same domain to also proxy /api/* through to the
    # backend, otherwise the admin panel's fetch() calls have nowhere to
    # resolve to.
    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
